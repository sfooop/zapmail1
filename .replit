modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "install", "--frozen-lockfile"]
env = { "CI" = "true" }

[workflows]
runButton = "Tempmail"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[[ports]]
localPort = 5173
externalPort = 80
